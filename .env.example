# ============================================
# 现代海龟协议量化交易系统 - Python后端环境配置
# ============================================

# 应用配置
APP_NAME="现代海龟协议量化交易系统"
DEBUG=False

# ============================================
# 数据库配置
# ============================================
# PostgreSQL连接字符串
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/turtle_trading

# ============================================
# 数据源配置
# ============================================
# Yahoo Finance (默认启用)
YAHOO_FINANCE_ENABLED=True

# Alpha Vantage (备用数据源) - 需要申请API Key
# 获取地址: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_api_key_here

# ============================================
# 交易策略参数 (海龟协议核心)
# ============================================
# 突破周期参数
ENTRY_PERIOD=20
EXIT_PERIOD=10
ATR_PERIOD=20

# 风险管理
RISK_PERCENTAGE=0.01

# 头寸限制
SINGLE_MARKET_LIMIT=4
CLOSELY_CORRELATED_LIMIT=6
LOOSELY_CORRELATED_LIMIT=10
SINGLE_DIRECTION_LIMIT=12

# ============================================
# 通知系统配置
# ============================================
NOTIFICATION_ENABLED=True

# SMTP邮件配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_TO=["recipient@example.com"]

# Webhook配置
WEBHOOK_URL=https://your-webhook-endpoint.com/notify

# ============================================
# 安全配置
# ============================================
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
